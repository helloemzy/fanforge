NODE_ENV=development
PORT=3000

# Base URL used in verification links.
APP_BASE_URL=http://localhost:3000

# Session and reader-shield signing secrets.
SESSION_SECRET=change-me
READER_SHIELD_SECRET=change-me

# Managed Postgres (required in production).
DATABASE_URL=
DATABASE_SSL=disable
DATABASE_POOL_MAX=12

# Resend verification email settings.
RESEND_API_KEY=
RESEND_FROM_EMAIL=reply@example.com
ALLOW_MANUAL_VERIFY_LINK=1

# Optional Cloudflare Turnstile challenge.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# S3-compatible object storage (required in production).
STORAGE_BUCKET=
STORAGE_REGION=auto
STORAGE_ENDPOINT=
STORAGE_PUBLIC_BASE_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=0

# Runtime marker used in Cloudflare Workers (set by wrangler vars).
CLOUDFLARE_RUNTIME=0
